7. Find Highest Unicode/ASCII char
function highest(str){
    let result=str[0];
    for(i=0;i<str.length;i++){
        if(str.charCodeAt(i) > result.charCodeAt(0)) result=str[i];
    }
    return result;
}
console.log(highest("cool yoyo"));

8. Replace "0" with "#"
   //input : tomorrow
   //output : t#m##rr###w

function replaceStr(str){
    let res="";
    let count=0;
    for(let i of str){
        if(i=="o"){
            count++;
            res += "#".repeat(count);
        }
        else{
            res += i;
        }
    }
    return res;
}
console.log(replaceStr("yo cool"));

9. Palindrome num
function isPlaindrome(num){
    let original = num;
    let res = 0;
    while (num>0){
        let remind = num%10;
        res = res*10+remind;
        num = Math.floor(num/10);
    }
    
    if(original===res){
        console.log("Palindrome");
    }
    else{
        console.log("Not Plaindrome");
    }
}
isPlaindrome(121);

10. Interchange
function interchange(word){
    let str = word.split(" ");
    let temp = str[0];
    str[0]=str[1];
    str[1]=str[2];
    str[2]=temp;
    return str.join(" ");
}
console.log(interchange("yoyo is cool"));

Or---------------->swap 1st and last
function swap(word){
    let str=word.split(" ");
    let temp=str[0];
    str[0]=str[str.length-1];
    str[str.length-1]=temp;
    return str.join(" ");
}
console.log(swap("yoyo is cool"));

11. Two arrays equal and same elements
function arrayEquals(a,b){
    if(a.length !== b.length) return false;
    for(let i=0; i<a.length; i++){
        if(a[i] !== b[i]) return false;
    }
    return true;
}
console.log(arrayEquals([1,2,3],[1,2,3]));

