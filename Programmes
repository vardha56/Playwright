1. print unique characters from str1 and str2
function unique(str1,str2){
    let result=[];
    
    for(let i=0;i<str1.length;i++){
        if(!str2.includes(str1[i])) result.push(str1[i]);
    }
    
    for(let j=0;j<str2.length;j++){
        if(!str1.includes(str2[j])) result.push(str2[j])
    }
    
    return result.join(" ");
}
console.log(unique("apple", "orange"));

