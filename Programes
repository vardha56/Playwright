1. Prog to count number of vowels

function countVowels(str){
	let count=0;
	const vowels="aeiouAEIOU";

for(const ch of str){
	if(vowels.includes(ch)){
	count++;
	}
}
console.log("Number of vowels in str are "+count)

}

countVowels("vardha");

2. To find Longest Word

function longestWord(str){
	let word=str.split(" ");
	let longest="";
	for(let i of word){
	if(i.length>longest.length){
	longest=i;
}
}
	console.log("Logest word is "+longest);
}
longestWord("Honey sigh is a rapper");

